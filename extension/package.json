{
  "name": "lex-academy-frontend",
  "displayName": "Lex: Academy",
  "packageManager": "pnpm@9.15.9",
  "description": "An 18-module frontend engineering course in VS Code: build one real store with AI-guided lessons.",
  "version": "1.0.4",
  "publisher": "lex-organization",
  "icon": "media/icon.png",
  "license": "MIT",
  "homepage": "https://github.com/Lex-Organization/lex-academy",
  "bugs": {
    "url": "https://github.com/Lex-Organization/lex-academy/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Lex-Organization/lex-academy"
  },
  "galleryBanner": {
    "color": "#0e3a5c",
    "theme": "dark"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Education"],
  "keywords": [
    "frontend",
    "course",
    "learn",
    "react",
    "nextjs",
    "typescript",
    "tailwind",
    "javascript",
    "html",
    "css",
    "vscode-course",
    "ai-assisted",
    "ai-tutor",
    "interactive",
    "tutorial"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "frontend-course",
          "title": "Lex: Academy",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "frontend-course": [
        {
          "type": "webview",
          "id": "frontendCourse.dashboard",
          "name": ""
        }
      ]
    },
    "commands": [
      {
        "command": "frontendCourse.openLesson",
        "title": "Lex: Academy - Open Dashboard"
      }
    ]
  },
  "scripts": {
    "build": "node build.js",
    "check": "tsc --noEmit",
    "test": "node --test test/*.test.js",
    "package": "pnpm build && npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.9.3",
    "@vscode/vsce": "^2.22.0"
  }
}
